<Window x:Class="ZapretikApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZapretikApp"
        mc:Ignorable="d"
        Title="Zapretik"
        Icon="pack://application:,,,/app.ico"
        Height="600"
        Width="920"
        MinHeight="520"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Cursor="Arrow"
        ForceCursor="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep" Color="#FF2B2B2E"/>
        <SolidColorBrush x:Key="BgCard" Color="#FF3E3E44"/>
        <SolidColorBrush x:Key="BorderMuted" Color="#FF4A4A52"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF0F0F2"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFA8A8B0"/>
        <SolidColorBrush x:Key="Accent" Color="#FF7C8CFF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF9AA6FF"/>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SubtitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- x:Shared=false — у каждой карточки свой transform -->
        <TransformGroup x:Key="CardEnterTransform" x:Shared="false">
            <TranslateTransform Y="18"/>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </TransformGroup>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="{StaticResource CardEnterTransform}"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Caption: minimize / close — soft white glow on hover -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Icon"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0.48"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Icon"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Icon"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.48"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Icon" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bottom action: bright label + soft brighten-on-hover -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Label"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0.92"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.92"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Label" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#664A4A52"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Label"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0.48"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.48"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Label" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Autostart ON — accent filled button -->
        <Style x:Key="AutostartOnButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{StaticResource Accent}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#AA9AA6FF"
                                BorderThickness="1">
                            <ContentPresenter x:Name="Label"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#887C8CFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF7C8CFF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#2A000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom thin scrollbar -->
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#55A8A8B0"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#88C8C8D0"/>
        <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#BB7C8CFF"/>

        <Style x:Key="ThinScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{StaticResource ScrollThumbBrush}"
                                CornerRadius="4"
                                Margin="2,0"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbDragBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalThinScrollBar" TargetType="ScrollBar">
            <!-- ClipToBounds=false + equal top/bottom track margins so thumb corners aren't clipped -->
            <Grid Width="10" Background="Transparent" ClipToBounds="False">
                <Border Background="{StaticResource ScrollTrackBrush}"
                        CornerRadius="5"
                        Margin="1,3"
                        Width="6"
                        HorizontalAlignment="Center"/>
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       Focusable="False"
                       Margin="0,3">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollBarThumb}"
                               MinHeight="28"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalThinScrollBar" TargetType="ScrollBar">
            <Grid Height="10" Background="Transparent" ClipToBounds="False">
                <Border Background="{StaticResource ScrollTrackBrush}"
                        CornerRadius="5"
                        Margin="3,1"
                        Height="6"
                        VerticalAlignment="Center"/>
                <Track x:Name="PART_Track"
                       IsDirectionReversed="False"
                       Focusable="False"
                       Margin="3,0">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollBarThumb}"
                               MinWidth="28"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource VerticalThinScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalThinScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmoothScrollViewerStyle" TargetType="{x:Type local:SmoothScrollViewer}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type local:SmoothScrollViewer}">
                        <Grid Background="{TemplateBinding Background}" ClipToBounds="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0"
                                                    Grid.Row="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanHorizontallyScroll="False"
                                                    CanVerticallyScroll="False"
                                                    ClipToBounds="True"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Grid.Row="0"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Margin="0,0,0,0"
                                       ClipToBounds="False"
                                       Cursor="Arrow"/>

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Column="0"
                                       Grid.Row="1"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Horizontal"
                                       Minimum="0"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       ClipToBounds="False"
                                       Cursor="Arrow"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,0,4,2"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">
                            <local:SmoothScrollViewer x:Name="BatScroller"
                                                      Style="{StaticResource SmoothScrollViewerStyle}"
                                                      Focusable="False"
                                                      Padding="{TemplateBinding Padding}"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      CanContentScroll="False"
                                                      ClipToBounds="False">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </local:SmoothScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!--
                          Selection/hover use Setters (not Enter/Exit storyboards).
                          ColorAnimations hold values after deselect and leave multiple items purple.
                        -->
                        <Border x:Name="ItemRoot"
                                Background="#18FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,10"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SelectBar"
                                        Grid.Column="0"
                                        Width="3"
                                        CornerRadius="2"
                                        Background="{StaticResource Accent}"
                                        Margin="0,1,8,1"
                                        Opacity="0"
                                        VerticalAlignment="Stretch"/>
                                <TextBlock x:Name="Icon"
                                           Grid.Column="1"
                                           Text="▶"
                                           Foreground="{StaticResource Accent}"
                                           Margin="0,0,10,0"
                                           Opacity="0.55"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock x:Name="Title"
                                               Text="{Binding Name}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Opacity="0.72"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="Sub"
                                               Text="{Binding RelativePath}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               Opacity="0.7"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover only when not selected -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="#28FFFFFF"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="Title" Property="Opacity" Value="1"/>
                                <Setter TargetName="Sub" Property="Opacity" Value="0.95"/>
                            </MultiTrigger>

                            <!-- Selected: only one item keeps purple -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#447C8CFF"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#AA7C8CFF"/>
                                <Setter TargetName="SelectBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="Title" Property="Opacity" Value="1"/>
                                <Setter TargetName="Sub" Property="Opacity" Value="1"/>
                            </Trigger>

                            <!-- Selected + hover -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="#557C8CFF"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#CC7C8CFF"/>
                                <Setter TargetName="SelectBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="Title" Property="Opacity" Value="1"/>
                                <Setter TargetName="Sub" Property="Opacity" Value="1"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Entrance storyboard -->
        <Storyboard x:Key="WindowEnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.94" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.94" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowChrome"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.32">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Cards cascade -->
            <DoubleAnimation Storyboard.TargetName="CardLeft"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardLeft"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CardRight"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardRight"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CardBottom"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBottom"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4" BeginTime="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="FooterActions"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.34">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Compact square icon button (folder browse) -->
        <Style x:Key="IconBrowseButton" TargetType="Button" BasedOn="{StaticResource BrowseButton}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="ToolTip" Value="Выбрать папку…"/>
        </Style>

        <!-- Settings row: title + description + action -->
        <Style x:Key="SettingsRowBorder" TargetType="Border">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="#334A4A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <!-- Shadow host (no corner radius — avoids edge fringing) -->
    <Border Margin="16"
            Background="Transparent"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              ShadowDepth="0"
                              Opacity="0.5"
                              Color="#FF000000"
                              RenderingBias="Quality"/>
        </Border.Effect>

        <!-- Real window surface: rounded + clipped in code-behind -->
        <Border x:Name="WindowChrome"
                CornerRadius="14"
                BorderBrush="#664A4A52"
                BorderThickness="1"
                Opacity="0"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True"
                RenderTransformOrigin="0.5,0.5"
                SizeChanged="WindowChrome_SizeChanged">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF2B2B2E" Offset="0"/>
                    <GradientStop Color="#FF252528" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.RenderTransform>
                <ScaleTransform x:Name="RootScale" ScaleX="0.94" ScaleY="0.94"/>
            </Border.RenderTransform>

            <Grid SnapsToDevicePixels="True" ClipToBounds="True">
                <!-- Ambient glow top-right -->
                <Ellipse Width="420" Height="420"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,-120,-100,0"
                         Opacity="0.18"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF7C8CFF" Offset="0"/>
                            <GradientStop Color="#007C8CFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Ambient glow bottom-left -->
                <Ellipse Width="360" Height="360"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"
                         Margin="-80,0,0,-100"
                         Opacity="0.12"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF9AA6FF" Offset="0"/>
                            <GradientStop Color="#009AA6FF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <DockPanel>
                    <!-- Custom title bar (narrower, top corners match window) -->
                    <Border x:Name="TitleBar"
                            DockPanel.Dock="Top"
                            Height="34"
                            CornerRadius="13,13,0,0"
                            Background="#10FFFFFF"
                            SnapsToDevicePixels="True"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid Margin="12,0,6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="18" Height="18"
                                        CornerRadius="5"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF7C8CFF" Offset="0"/>
                                            <GradientStop Color="#FF5A6AE0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Z"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Zapretik"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAppVersion"
                                               Text="v1.0.0"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Opacity="0.85"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="BtnMinimize"
                                        Style="{StaticResource CaptionButton}"
                                        ToolTip="Свернуть в панель задач"
                                        Click="BtnMinimize_Click">
                                    <Path Data="M 0,0.5 L 10,0.5"
                                          Stroke="White"
                                          StrokeThickness="1.5"
                                          Stretch="None"
                                          Width="10" Height="1"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="BtnClose"
                                        Style="{StaticResource CaptionButton}"
                                        ToolTip="Закрыть"
                                        Click="BtnClose_Click">
                                    <Path Data="M 0,0 L 9,9 M 9,0 L 0,9"
                                          Stroke="White"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Width="9" Height="9"
                                          Stretch="None"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <DockPanel Margin="28,18,28,24">
                        <!-- Header -->
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,22">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40"
                                        CornerRadius="10"
                                        Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF7C8CFF" Offset="0"/>
                                            <GradientStop Color="#FF5A6AE0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Z"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtMachineName"
                                               Text="PC"
                                               Style="{StaticResource TitleText}"/>
                                    <TextBlock Text="Пользователь"
                                               Style="{StaticResource SubtitleText}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="BtnSettings"
                                    DockPanel.Dock="Right"
                                    Content="Настройки"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,8"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Click="BtnSettings_Click"
                                    ToolTip="Автозапуск, загрузка Zapret, обновления"/>
                        </DockPanel>

                        <!-- Footer: GitHub left, actions right -->
                        <DockPanel x:Name="FooterActions"
                                   DockPanel.Dock="Bottom"
                                   Margin="0,20,0,0"
                                   Opacity="0"
                                   LastChildFill="False">
                            <Button x:Name="BtnGitHub"
                                    DockPanel.Dock="Left"
                                    Content="GitHub"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,10"
                                    VerticalAlignment="Center"
                                    Click="BtnGitHub_Click"
                                    ToolTip="Открыть репозиторий Zapretik на GitHub"/>
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="BtnStop"
                                        Content="Снять службу"
                                        Style="{StaticResource GhostButton}"
                                        Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="BtnStop_Click"/>
                                <Button x:Name="BtnStart"
                                        Content="Установить службу"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="BtnStart_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Main content cards + settings overlay -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="CardLeft"
                                    Grid.Column="0" Grid.Row="0"
                                    Style="{StaticResource CardBorder}"
                                    MinHeight="220"
                                    Padding="20,18,20,16">
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="Статус"
                                               Style="{StaticResource TitleText}"
                                               FontSize="16"
                                               Margin="0,0,0,6"/>
                                    <TextBlock x:Name="TxtStatusDescription"
                                               DockPanel.Dock="Top"
                                               Text="Укажите корневую папку Zapret, чтобы приложение могло с ним работать."
                                               Style="{StaticResource SubtitleText}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="40"
                                               Margin="0,0,0,14"
                                               LineHeight="18"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                                    <!-- Status metrics: always stacked so nothing gets clipped -->
                                    <Border Background="#22000000"
                                            CornerRadius="10"
                                            Padding="14,12,14,14"
                                            VerticalAlignment="Stretch"
                                            Margin="0,0,0,2"
                                            ClipToBounds="False">
                                        <StackPanel VerticalAlignment="Top">
                                            <!-- Connection + Uptime side by side -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Соединение"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                    <TextBlock x:Name="TxtStatusCardConnection"
                                                               Text="Отключен"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,4,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- Hidden: kept for code that still updates connection label -->
                                                    <TextBlock x:Name="TxtConnectionStatus"
                                                               Visibility="Collapsed"
                                                               Text="Отключен"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Аптайм"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                    <TextBlock x:Name="TxtUptime"
                                                               Text="—"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border Height="1" Background="#224A4A52" Margin="0,0,0,12"/>

                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Активный скрипт"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"/>
                                                <TextBlock x:Name="TxtActiveBat"
                                                           Text="—"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="Последний запуск"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"/>
                                                <!-- Name + time on one line so the date is never clipped at the bottom -->
                                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                                    <TextBlock x:Name="TxtLastBatTime"
                                                               DockPanel.Dock="Right"
                                                               Text=""
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                                    <TextBlock x:Name="TxtLastBat"
                                                               Text="Ещё не запускался"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <Border x:Name="CardRight"
                                    Grid.Column="2" Grid.Row="0"
                                    Style="{StaticResource CardBorder}">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10" LastChildFill="False">
                                        <TextBlock Text="Скрипты .bat"
                                                   Style="{StaticResource TitleText}"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtBatCount"
                                                   DockPanel.Dock="Right"
                                                   Text="0"
                                                   Style="{StaticResource SubtitleText}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <TextBlock x:Name="TxtBatHint"
                                               DockPanel.Dock="Top"
                                               Text="Выберите папку Zapret — здесь появятся bat-файлы."
                                               Style="{StaticResource SubtitleText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"
                                               LineHeight="18"/>

                                    <Grid>
                                        <ListBox x:Name="LstBatFiles"
                                                 Style="{StaticResource BatListBox}"
                                                 ItemContainerStyle="{StaticResource BatListBoxItem}"
                                                 SelectionChanged="LstBatFiles_SelectionChanged"
                                                 Visibility="Collapsed"/>

                                        <TextBlock x:Name="TxtBatEmpty"
                                                   Text="Файлы .bat / .cmd не найдены"
                                                   Style="{StaticResource SubtitleText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Opacity="0.7"
                                                   Visibility="Collapsed"/>
                                    </Grid>
                                </DockPanel>
                            </Border>

                            <Border x:Name="CardBottom"
                                    Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16,12">
                                <DockPanel LastChildFill="True">
                                    <!-- Download progress (shown while fetching Zapret) -->
                                    <StackPanel x:Name="PanelDownloadProgress"
                                                DockPanel.Dock="Top"
                                                Margin="0,0,0,12"
                                                Visibility="Collapsed">
                                        <DockPanel LastChildFill="True" Margin="0,0,0,6">
                                            <Button x:Name="BtnCancelDownload"
                                                    DockPanel.Dock="Right"
                                                    Content="Отмена"
                                                    Style="{StaticResource BrowseButton}"
                                                    Padding="12,4"
                                                    FontSize="11"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0"
                                                    Click="BtnCancelDownload_Click"
                                                    ToolTip="Отменить скачивание Zapret"/>
                                            <TextBlock x:Name="TxtDownloadPercent"
                                                       DockPanel.Dock="Right"
                                                       Text="0%"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                            <TextBlock x:Name="TxtDownloadProgress"
                                                       Text="Скачивание Zapret…"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                        </DockPanel>
                                        <ProgressBar x:Name="BarDownload"
                                                     Height="8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="0"
                                                     BorderThickness="0"
                                                     Background="#33000000"
                                                     Foreground="{StaticResource Accent}"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="6" Height="38"
                                                CornerRadius="3"
                                                Background="{StaticResource Accent}"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock Text="Корневая папка Zapret"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="TxtZapretPath"
                                                       Text="Путь не выбран"
                                                       Style="{StaticResource SubtitleText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0"
                                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                        </StackPanel>

                                        <Button x:Name="BtnZapretSettings"
                                                Grid.Column="2"
                                                Style="{StaticResource IconBrowseButton}"
                                                VerticalAlignment="Center"
                                                IsEnabled="False"
                                                Click="BtnZapretSettings_Click"
                                                ToolTip="Настройки Zapret: IP, статус, Game Filter, IPSet Filter">
                                            <!-- Gray gear icon -->
                                            <Path Width="15" Height="15"
                                                  Stretch="Uniform"
                                                  Fill="#FFA8A8B0"
                                                  Data="M12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.52,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.66 4.57,12.98L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.34 8.52,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.48,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98Z"/>
                                        </Button>

                                        <Button x:Name="BtnBrowseZapretCard"
                                                Grid.Column="4"
                                                Style="{StaticResource IconBrowseButton}"
                                                VerticalAlignment="Center"
                                                Click="BtnBrowseZapret_Click"
                                                ToolTip="Выбрать папку Zapret…">
                                            <!-- Gray folder icon -->
                                            <Path Width="16" Height="13"
                                                  Stretch="Uniform"
                                                  Fill="#FFA8A8B0"
                                                  Data="M1.5,3.2 C1.5,2.4 2.15,1.75 2.95,1.75 L7.1,1.75 L8.55,3.2 L17.05,3.2 C17.85,3.2 18.5,3.85 18.5,4.65 L18.5,13.8 C18.5,14.6 17.85,15.25 17.05,15.25 L2.95,15.25 C2.15,15.25 1.5,14.6 1.5,13.8 Z"/>
                                        </Button>
                                    </Grid>
                                </DockPanel>
                            </Border>

                        </Grid>
                    </DockPanel>
                </DockPanel>

                <!-- Settings overlay: dims the entire app (title bar + content) -->
                <Grid x:Name="SettingsOverlay"
                      Visibility="Collapsed"
                      Panel.ZIndex="100">
                    <Border Background="#AA000000"
                            CornerRadius="14"
                            MouseLeftButtonDown="SettingsOverlayDim_MouseLeftButtonDown"/>
                    <Border MaxWidth="500"
                            MaxHeight="560"
                            MinWidth="440"
                            Margin="28"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{StaticResource BgCard}"
                            BorderBrush="{StaticResource BorderMuted}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="24,22">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16" LastChildFill="True">
                                <Button x:Name="BtnCloseSettings"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource CaptionButton}"
                                        Width="32" Height="28"
                                        ToolTip="Закрыть"
                                        Click="BtnCloseSettings_Click">
                                    <Path Data="M 0,0 L 9,9 M 9,0 L 0,9"
                                          Stroke="White"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Width="9" Height="9"
                                          Stretch="None"/>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Настройки"
                                               Style="{StaticResource TitleText}"
                                               FontSize="18"/>
                                    <TextBlock Text="Автозапуск, Zapret и обновления"
                                               Style="{StaticResource SubtitleText}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>

                            <local:SmoothScrollViewer Style="{StaticResource SmoothScrollViewerStyle}"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      CanContentScroll="False">
                                <StackPanel>
                                    <!-- Autostart -->
                                    <Border Style="{StaticResource SettingsRowBorder}">
                                        <DockPanel LastChildFill="True">
                                            <Button x:Name="BtnAutostart"
                                                    DockPanel.Dock="Right"
                                                    Content="Выкл"
                                                    Style="{StaticResource BrowseButton}"
                                                    MinWidth="72"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0"
                                                    Click="BtnAutostart_Click"/>
                                            <StackPanel>
                                                <TextBlock Text="Автозапуск"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Запускать Zapretik вместе с Windows. Окно сразу уходит в трей, чтобы не мешать."
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           LineHeight="15"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <!-- Download Zapret -->
                                    <Border Style="{StaticResource SettingsRowBorder}">
                                        <DockPanel LastChildFill="True">
                                            <Button x:Name="BtnNoZapret"
                                                    DockPanel.Dock="Right"
                                                    Content="Скачать"
                                                    Style="{StaticResource BrowseButton}"
                                                    MinWidth="72"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0"
                                                    Click="BtnNoZapret_Click"
                                                    ToolTip="Скачать Zapret с Google Drive"/>
                                            <StackPanel>
                                                <TextBlock Text="Нет папки Zapret"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Скачает дистрибутив с Google Drive на рабочий стол и сразу укажет путь в приложении."
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           LineHeight="15"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <!-- Updates -->
                                    <Border Style="{StaticResource SettingsRowBorder}" Margin="0">
                                        <DockPanel LastChildFill="True">
                                            <Button x:Name="BtnCheckUpdate"
                                                    DockPanel.Dock="Right"
                                                    Content="Проверить"
                                                    Style="{StaticResource BrowseButton}"
                                                    MinWidth="72"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0"
                                                    Click="BtnCheckUpdate_Click"
                                                    ToolTip="Проверить обновления (GitHub Releases + зеркала)"/>
                                            <StackPanel>
                                                <TextBlock Text="Обновления"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="Проверить, есть ли новая версия Zapretik. При обновлении приложение перезапустится."
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           LineHeight="15"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </local:SmoothScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
