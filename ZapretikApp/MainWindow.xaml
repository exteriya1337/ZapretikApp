<Window x:Class="ZapretikApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZapretikApp"
        mc:Ignorable="d"
        Title="Zapretik"
        Height="600"
        Width="920"
        MinHeight="520"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Cursor="Arrow"
        ForceCursor="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep" Color="#FF2B2B2E"/>
        <SolidColorBrush x:Key="BgCard" Color="#FF3E3E44"/>
        <SolidColorBrush x:Key="BorderMuted" Color="#FF4A4A52"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF0F0F2"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFA8A8B0"/>
        <SolidColorBrush x:Key="Accent" Color="#FF7C8CFF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF9AA6FF"/>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SubtitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- x:Shared=false — у каждой карточки свой transform -->
        <TransformGroup x:Key="CardEnterTransform" x:Shared="false">
            <TranslateTransform Y="18"/>
            <ScaleTransform ScaleX="1" ScaleY="1"/>
        </TransformGroup>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="{StaticResource CardEnterTransform}"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Caption: minimize / close — soft white glow on hover -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                Padding="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="Icon"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0.48"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Icon"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Icon"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.48"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Icon" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bottom action: bright label + soft brighten-on-hover -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Label"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0.92"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.92"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Label" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#664A4A52"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="Label"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0.48"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Label"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.48"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Label" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Autostart ON — accent filled button -->
        <Style x:Key="AutostartOnButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{StaticResource Accent}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#AA9AA6FF"
                                BorderThickness="1">
                            <ContentPresenter x:Name="Label"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="1"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMuted}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#887C8CFF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF7C8CFF"/>
                                <Setter TargetName="Bd" Property="Background" Value="#2A000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom thin scrollbar -->
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#55A8A8B0"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#88C8C8D0"/>
        <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#BB7C8CFF"/>

        <Style x:Key="ThinScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{StaticResource ScrollThumbBrush}"
                                CornerRadius="4"
                                Margin="1"
                                SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbDragBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalThinScrollBar" TargetType="ScrollBar">
            <Grid Width="10" Background="Transparent">
                <Border Background="{StaticResource ScrollTrackBrush}"
                        CornerRadius="5"
                        Margin="1,2"
                        Width="6"
                        HorizontalAlignment="Center"/>
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True"
                       Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollBarThumb}"
                               MinHeight="28"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalThinScrollBar" TargetType="ScrollBar">
            <Grid Height="10" Background="Transparent">
                <Border Background="{StaticResource ScrollTrackBrush}"
                        CornerRadius="5"
                        Margin="2,1"
                        Height="6"
                        VerticalAlignment="Center"/>
                <Track x:Name="PART_Track"
                       IsDirectionReversed="False"
                       Focusable="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollBarThumb}"
                               MinWidth="28"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ThinScrollBarPageButton}"
                                      Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="False"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource VerticalThinScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalThinScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmoothScrollViewerStyle" TargetType="{x:Type local:SmoothScrollViewer}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type local:SmoothScrollViewer}">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0"
                                                    Grid.Row="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanHorizontallyScroll="False"
                                                    CanVerticallyScroll="False"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Grid.Row="0"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Cursor="Arrow"/>

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Column="0"
                                       Grid.Row="1"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Horizontal"
                                       Minimum="0"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Cursor="Arrow"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <local:SmoothScrollViewer x:Name="BatScroller"
                                                      Style="{StaticResource SmoothScrollViewerStyle}"
                                                      Focusable="False"
                                                      Padding="{TemplateBinding Padding}"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      CanContentScroll="False">
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </local:SmoothScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BatListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!--
                          Selection/hover use Setters (not Enter/Exit storyboards).
                          ColorAnimations hold values after deselect and leave multiple items purple.
                        -->
                        <Border x:Name="ItemRoot"
                                Background="#18FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,10"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="SelectBar"
                                        Grid.Column="0"
                                        Width="3"
                                        CornerRadius="2"
                                        Background="{StaticResource Accent}"
                                        Margin="0,1,8,1"
                                        Opacity="0"
                                        VerticalAlignment="Stretch"/>
                                <TextBlock x:Name="Icon"
                                           Grid.Column="1"
                                           Text="▶"
                                           Foreground="{StaticResource Accent}"
                                           Margin="0,0,10,0"
                                           Opacity="0.55"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock x:Name="Title"
                                               Text="{Binding Name}"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Opacity="0.72"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="Sub"
                                               Text="{Binding RelativePath}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,2,0,0"
                                               Opacity="0.7"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover only when not selected -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="#28FFFFFF"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="Title" Property="Opacity" Value="1"/>
                                <Setter TargetName="Sub" Property="Opacity" Value="0.95"/>
                            </MultiTrigger>

                            <!-- Selected: only one item keeps purple -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#447C8CFF"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#AA7C8CFF"/>
                                <Setter TargetName="SelectBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="Title" Property="Opacity" Value="1"/>
                                <Setter TargetName="Sub" Property="Opacity" Value="1"/>
                            </Trigger>

                            <!-- Selected + hover -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemRoot" Property="Background" Value="#557C8CFF"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#CC7C8CFF"/>
                                <Setter TargetName="SelectBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Icon" Property="Opacity" Value="1"/>
                                <Setter TargetName="Title" Property="Opacity" Value="1"/>
                                <Setter TargetName="Sub" Property="Opacity" Value="1"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Entrance storyboard -->
        <Storyboard x:Key="WindowEnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.94" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.94" To="1" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WindowChrome"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.32">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <!-- Cards cascade -->
            <DoubleAnimation Storyboard.TargetName="CardLeft"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardLeft"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CardRight"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardRight"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="CardBottom"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.35" BeginTime="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBottom"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4" BeginTime="0:0:0.28">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="FooterActions"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.34">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Online badge pulse -->
        <Storyboard x:Key="OnlinePulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="OnlineDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0.35" Duration="0:0:1.1"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OnlineDotScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.35" Duration="0:0:1.1"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OnlineDotScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.35" Duration="0:0:1.1"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <!-- Shadow host (no corner radius — avoids edge fringing) -->
    <Border Margin="16"
            Background="Transparent"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              ShadowDepth="0"
                              Opacity="0.5"
                              Color="#FF000000"
                              RenderingBias="Quality"/>
        </Border.Effect>

        <!-- Real window surface: rounded + clipped in code-behind -->
        <Border x:Name="WindowChrome"
                CornerRadius="14"
                BorderBrush="#664A4A52"
                BorderThickness="1"
                Opacity="0"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True"
                RenderTransformOrigin="0.5,0.5"
                SizeChanged="WindowChrome_SizeChanged">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF2B2B2E" Offset="0"/>
                    <GradientStop Color="#FF252528" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.RenderTransform>
                <ScaleTransform x:Name="RootScale" ScaleX="0.94" ScaleY="0.94"/>
            </Border.RenderTransform>

            <Grid SnapsToDevicePixels="True" ClipToBounds="True">
                <!-- Ambient glow top-right -->
                <Ellipse Width="420" Height="420"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,-120,-100,0"
                         Opacity="0.18"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF7C8CFF" Offset="0"/>
                            <GradientStop Color="#007C8CFF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Ambient glow bottom-left -->
                <Ellipse Width="360" Height="360"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"
                         Margin="-80,0,0,-100"
                         Opacity="0.12"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF9AA6FF" Offset="0"/>
                            <GradientStop Color="#009AA6FF" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <DockPanel>
                    <!-- Custom title bar (narrower, top corners match window) -->
                    <Border x:Name="TitleBar"
                            DockPanel.Dock="Top"
                            Height="34"
                            CornerRadius="13,13,0,0"
                            Background="#10FFFFFF"
                            SnapsToDevicePixels="True"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid Margin="12,0,6,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="18" Height="18"
                                        CornerRadius="5"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF7C8CFF" Offset="0"/>
                                            <GradientStop Color="#FF5A6AE0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Z"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Zapretik"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtAppVersion"
                                               Text="v1.0.0"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Opacity="0.85"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="BtnMinimize"
                                        Style="{StaticResource CaptionButton}"
                                        ToolTip="Свернуть"
                                        Click="BtnMinimize_Click">
                                    <Path Data="M 0,0.5 L 10,0.5"
                                          Stroke="White"
                                          StrokeThickness="1.5"
                                          Stretch="None"
                                          Width="10" Height="1"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="BtnClose"
                                        Style="{StaticResource CaptionButton}"
                                        ToolTip="Закрыть"
                                        Click="BtnClose_Click">
                                    <Path Data="M 0,0 L 9,9 M 9,0 L 0,9"
                                          Stroke="White"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Width="9" Height="9"
                                          Stretch="None"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <DockPanel Margin="28,18,28,24">
                        <!-- Header -->
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,22">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="40" Height="40"
                                        CornerRadius="10"
                                        Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF7C8CFF" Offset="0"/>
                                            <GradientStop Color="#FF5A6AE0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Z"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtMachineName"
                                               Text="PC"
                                               Style="{StaticResource TitleText}"/>
                                    <TextBlock Text="Пользователь"
                                               Style="{StaticResource SubtitleText}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Border x:Name="StatusBadge"
                                    DockPanel.Dock="Right"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="12,6"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.Background>
                                    <SolidColorBrush x:Name="StatusBadgeBg" Color="#22FFFFFF"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush x:Name="StatusBadgeBorder" Color="#FF4A4A52"/>
                                </Border.BorderBrush>
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="StatusBadgeScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="StatusBadgeBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#33FFFFFF"
                                                                Duration="0:0:0.18"/>
                                                <DoubleAnimation Storyboard.TargetName="StatusBadgeScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1.04" Duration="0:0:0.18"/>
                                                <DoubleAnimation Storyboard.TargetName="StatusBadgeScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 To="1.04" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="StatusBadgeBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#22FFFFFF"
                                                                Duration="0:0:0.18"/>
                                                <DoubleAnimation Storyboard.TargetName="StatusBadgeScale"
                                                                 Storyboard.TargetProperty="ScaleX"
                                                                 To="1" Duration="0:0:0.18"/>
                                                <DoubleAnimation Storyboard.TargetName="StatusBadgeScale"
                                                                 Storyboard.TargetProperty="ScaleY"
                                                                 To="1" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse x:Name="OnlineDot"
                                                 Fill="#FF8A8A92"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <ScaleTransform x:Name="OnlineDotScale"/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock x:Name="TxtConnectionStatus"
                                               Text="Отключен"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DockPanel>

                        <!-- Footer: GitHub left, actions right -->
                        <DockPanel x:Name="FooterActions"
                                   DockPanel.Dock="Bottom"
                                   Margin="0,20,0,0"
                                   Opacity="0"
                                   LastChildFill="False">
                            <Button x:Name="BtnGitHub"
                                    DockPanel.Dock="Left"
                                    Content="GitHub"
                                    Style="{StaticResource GhostButton}"
                                    Padding="14,10"
                                    VerticalAlignment="Center"
                                    Click="BtnGitHub_Click"
                                    ToolTip="Открыть репозиторий Zapretik на GitHub"/>
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button x:Name="BtnStop"
                                        Content="Снять службу"
                                        Style="{StaticResource GhostButton}"
                                        Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="BtnStop_Click"/>
                                <Button x:Name="BtnStart"
                                        Content="Установить службу"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="BtnStart_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- Main content cards -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="CardLeft"
                                    Grid.Column="0" Grid.Row="0"
                                    Style="{StaticResource CardBorder}"
                                    MinHeight="220">
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="Статус"
                                               Style="{StaticResource TitleText}"
                                               FontSize="16"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TxtStatusDescription"
                                               DockPanel.Dock="Top"
                                               Text="Укажите корневую папку Zapret, чтобы приложение могло с ним работать."
                                               Style="{StaticResource SubtitleText}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="36"
                                               Margin="0,0,0,10"
                                               LineHeight="18"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                                    <!-- Status metrics: always stacked so nothing gets clipped -->
                                    <Border Background="#22000000"
                                            CornerRadius="10"
                                            Padding="14,12"
                                            VerticalAlignment="Stretch"
                                            ClipToBounds="False">
                                        <StackPanel VerticalAlignment="Top">
                                            <!-- Connection + Uptime side by side -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Соединение"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                    <TextBlock x:Name="TxtStatusCardConnection"
                                                               Text="Отключен"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,4,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Аптайм"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"/>
                                                    <TextBlock x:Name="TxtUptime"
                                                               Text="—"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border Height="1" Background="#224A4A52" Margin="0,0,0,12"/>

                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="Активный скрипт"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"/>
                                                <TextBlock x:Name="TxtActiveBat"
                                                           Text="—"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,2">
                                                <TextBlock Text="Последний запуск"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           FontSize="11"/>
                                                <!-- Name + time on one line so the date is never clipped at the bottom -->
                                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                                    <TextBlock x:Name="TxtLastBatTime"
                                                               DockPanel.Dock="Right"
                                                               Text=""
                                                               Foreground="{StaticResource TextSecondary}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                                    <TextBlock x:Name="TxtLastBat"
                                                               Text="Ещё не запускался"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <Border x:Name="CardRight"
                                    Grid.Column="2" Grid.Row="0"
                                    Style="{StaticResource CardBorder}">
                                <DockPanel>
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10" LastChildFill="False">
                                        <TextBlock Text="Скрипты .bat"
                                                   Style="{StaticResource TitleText}"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtBatCount"
                                                   DockPanel.Dock="Right"
                                                   Text="0"
                                                   Style="{StaticResource SubtitleText}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>

                                    <TextBlock x:Name="TxtBatHint"
                                               DockPanel.Dock="Top"
                                               Text="Выберите папку Zapret — здесь появятся bat-файлы."
                                               Style="{StaticResource SubtitleText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"
                                               LineHeight="18"/>

                                    <Grid>
                                        <ListBox x:Name="LstBatFiles"
                                                 Style="{StaticResource BatListBox}"
                                                 ItemContainerStyle="{StaticResource BatListBoxItem}"
                                                 SelectionChanged="LstBatFiles_SelectionChanged"
                                                 Visibility="Collapsed"/>

                                        <TextBlock x:Name="TxtBatEmpty"
                                                   Text="Файлы .bat / .cmd не найдены"
                                                   Style="{StaticResource SubtitleText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Opacity="0.7"
                                                   Visibility="Collapsed"/>
                                    </Grid>
                                </DockPanel>
                            </Border>

                            <Border x:Name="CardBottom"
                                    Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                    Style="{StaticResource CardBorder}"
                                    Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="6" Height="38"
                                            CornerRadius="3"
                                            Background="{StaticResource Accent}"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="Корневая папка Zapret"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="TxtZapretPath"
                                                   Text="Путь не выбран"
                                                   Style="{StaticResource SubtitleText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,0"
                                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                    </StackPanel>

                                    <Button x:Name="BtnBrowseZapretCard"
                                            Grid.Column="2"
                                            Content="Обзор…"
                                            Style="{StaticResource BrowseButton}"
                                            VerticalAlignment="Center"
                                            Click="BtnBrowseZapret_Click"/>

                                    <Button x:Name="BtnOpenIpset"
                                            Grid.Column="4"
                                            Content="IP-адреса…"
                                            Style="{StaticResource BrowseButton}"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Click="BtnOpenIpset_Click"
                                            ToolTip="Добавить / удалить записи в lists\ipset-all.txt"/>

                                    <Button x:Name="BtnAutostart"
                                            Grid.Column="6"
                                            Content="Автозапуск: выкл"
                                            Style="{StaticResource BrowseButton}"
                                            VerticalAlignment="Center"
                                            Click="BtnAutostart_Click"
                                            ToolTip="Запускать Zapretik вместе с Windows (в трей)"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Border>
</Window>
